# --- Server ---
PORT=3001
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:3001
# Internet-reachable platform API URL baked into every provisioned site's
# VITE_CONTENT_API (.env.production + Vercel env). Set this to your Render
# URL in production so deployed child sites don't try to hit localhost.
# Example: DEPLOYED_CONTENT_API_URL=https://api.yourdomain.com
DEPLOYED_CONTENT_API_URL=
ADMIN_EMAIL=kisora@apotomelabs.com

# --- Database (Postgres) ---
DATABASE_URL=postgres://user:pass@localhost:5432/archetype
DATABASE_SSL=false
# Postgres schema for all archetype-service tables. Keeps this service safely
# isolated when sharing a database with sibling services (e.g. apotome-labs,
# which uses the default `public` schema). Override only if you know why.
DB_SCHEMA=archetype

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Auth (magic link) ---
JWT_SECRET=change-me-in-prod
COOKIE_DOMAIN=
COOKIE_SECURE=false

# --- Email (nodemailer) ---
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@apotomelabs.com

# --- Stripe: platform billing (Apotome's own revenue) ---
# Used by OrdersService for wizard checkout (customers buying a website) and
# its webhook. This is YOUR business account.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Stripe: vendor payments (Connect platform account) ---
# Used by PaymentsService + storefront checkouts (shop/ticketing) for owner
# Connect onboarding, Plaid bank attach, and destination charges. Set this to
# the Connect-enabled account's key to keep vendor money on a separate Stripe
# account; leave EMPTY to run everything on STRIPE_SECRET_KEY (one account).
STRIPE_CONNECT_SECRET_KEY=

# Used to build Stripe Connect onboarding return URLs and shop checkout
# success/cancel URLs when the browser origin isn't available.
PUBLIC_APP_URL=http://localhost:5173

# --- Plaid (owner bank linking → Stripe Connect payout account) ---
# Get keys at https://dashboard.plaid.com. Use sandbox for testing.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
STRIPE_SUCCESS_URL=http://localhost:5173/wizard?status=success&order={ORDER_ID}
STRIPE_CANCEL_URL=http://localhost:5173/wizard?status=cancelled
# One env per SKU (see archetype-shared/src/pricing.ts) — set the Stripe Price ID
STRIPE_PRICE_WEBSITE_ESSENTIALS=
STRIPE_PRICE_WEBSITE_PORTFOLIO=
STRIPE_PRICE_WEBSITE_EXTENDED=
STRIPE_PRICE_TUNEUP=
STRIPE_PRICE_PHOTO=
STRIPE_PRICE_PHOTO_EXTENDED=
STRIPE_PRICE_GMAPS=
STRIPE_PRICE_GSC=
STRIPE_PRICE_INSTA_GMAPS=
STRIPE_PRICE_BUNDLE_STARTER=
STRIPE_PRICE_BUNDLE_PRO=
STRIPE_PRICE_BUNDLE_PREMIUM=

# --- GitHub (provisioning) ---
GITHUB_TOKEN=
GITHUB_ORG=apotome-labs
GITHUB_TEMPLATE_MESA=archetype-mesa-template-ui
GITHUB_TEMPLATE_HEARTH=archetype-hearth-template-ui
GITHUB_TEMPLATE_VAULT=archetype-vault-template-ui
GITHUB_TEMPLATE_MARQUEE=archetype-marquee-template-ui
GITHUB_TEMPLATE_KEYSTONE=archetype-keystone-template-ui

# --- Vercel (provisioning + domains + analytics) ---
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# --- Vercel Blob (media uploads + screenshot cache) ---
# When set, the screenshot service stores cached PNGs in Vercel Blob instead of /tmp,
# so caches survive Render restarts and work across multiple service instances.
BLOB_READ_WRITE_TOKEN=

# --- Screenshot capture ---
# Set to true on Render (and other slim Linux hosts) so the screenshot service
# uses @sparticuz/chromium + puppeteer-core. The bundled puppeteer Chromium is
# not present on Render's base image.
SCREENSHOT_USE_SERVERLESS_CHROMIUM=false
# Optional: override cache directory (disk fallback only, ignored when using Blob).
# SCREENSHOT_CACHE_DIR=
# Optional: cache TTL in hours (default 1).
# SCREENSHOT_TTL_HOURS=1

# --- CORS ---
# Comma-separated list of always-allowed origins; live custom domains are added dynamically.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Integrations ---
GOOGLE_PLACES_API_KEY=
# Instagram API with Instagram Login (Basic Display was shut down 2024-12-04).
# Use the *Instagram-product* App ID/secret from the Meta app's
# Instagram > API setup with Instagram business login screen — NOT the Meta app ID.
# Register `${PUBLIC_BASE_URL}/v1/instagram/callback` as an OAuth redirect URI
# there (exact match, HTTPS required — use a tunnel for local testing).
# Connected accounts must be IG professional accounts (Business/Creator).
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# AI copy assistant — Google Gemini (gemini-1.5-flash by default)
GEMINI_API_KEY=
HCAPTCHA_SECRET=

# --- Feature flags ---
FEATURE_PROVISIONING=true
FEATURE_UPTIME=true
